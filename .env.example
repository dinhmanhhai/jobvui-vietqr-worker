# PostgreSQL (database xumxue)
DATABASE_URL="postgresql://xumxue:PASSWORD@10.0.1.98:5432/xumxue"

# Redis cache cho bearer token
REDIS_URL=redis://redis:6379
VIETQR_TOKEN_REDIS_KEY=vietqr:bearer_token

# VietQR login (POST /vqr/api/accounts)
VIETQR_LOGIN_PHONE=0818071599
VIETQR_LOGIN_PASSWORD=        # lưu ý: có thể cần dạng HASH mà UI vietqr.vn gửi (không phải plaintext)
VIETQR_BANK_ID=
VIETQR_QUERY_VALUE=          # số TK nhận tiền (hoặc phone) để query giao dịch 1 TK cố định
# VIETQR_SESSION_COOKIE=
# VIETQR_API_BASE=https://api.vietqr.org
# VIETQR_TRANSACTION_TYPE=3
# VIETQR_LOOKBACK_DAYS=3
# POLL_INTERVAL_MS=5000
# BOOKING_EXPIRE_HOURS=24

# HTTP API
PORT=8080
CORS_ORIGIN=https://xumxuecoffee.com

# Email (SendGrid)
SENDGRID_API_KEY=
SENDGRID_FROM=        # email người gửi đã verify trên SendGrid
